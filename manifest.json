{
  "manifest_version": 3,
  "name": "SoundCloud True Shuffle",
  "version": "1.0.0",
  "description": "Shuffles your entire liked-tracks library instead of only the page that happens to be loaded.",
  "permissions": [
    "webRequest",
    "storage",
    "unlimitedStorage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://api-v2.soundcloud.com/*",
    "https://soundcloud.com/*",
    "https://*.sndcdn.com/*",
    "https://api-widget.soundcloud.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "True Shuffle",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
